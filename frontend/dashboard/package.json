    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.0.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "vitest": "^3.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
